# ==========================================
# Configuracoes do Projeto Full-Stack
# ==========================================

# Ambiente
NODE_ENV=production

# Backend
PORT=3000

# MongoDB (NoSQL)
MONGODB_URI=mongodb://mongodb:27017/apidb

# PostgreSQL (SQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=apidb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost

# Frontend
VITE_API_URL=/api
